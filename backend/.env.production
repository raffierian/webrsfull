# ========================================
# SERVER CONFIGURATION
# ========================================
NODE_ENV=production
PORT=5000
API_URL=https://api.rssoewandhie.com

# ========================================
# DATABASE CONFIGURATION (PostgreSQL)
# ========================================
# ⚠️ WAJIB DIGANTI oleh petugas server
DATABASE_URL="postgresql://USERNAME:PASSWORD@localhost:5432/rssoewandhie?schema=public"

# ========================================
# JWT CONFIGURATION
# ========================================
# ⚠️ WAJIB DIGANTI dengan random string (minimal 32 karakter)
# Generate dengan: openssl rand -base64 32
JWT_SECRET=GENERATE_RANDOM_STRING_MINIMAL_32_KARAKTER
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=GENERATE_RANDOM_STRING_BERBEDA_MINIMAL_32_KARAKTER
JWT_REFRESH_EXPIRES_IN=30d

# ========================================
# CORS CONFIGURATION
# ========================================
# ⚠️ GANTI dengan domain frontend production
CORS_ORIGIN=https://rssoewandhie.com

# ========================================
# FILE UPLOAD CONFIGURATION
# ========================================
MAX_FILE_SIZE=5242880
UPLOAD_PATH=./uploads

# ========================================
# PAGINATION
# ========================================
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# ========================================
# SMTP / EMAIL CONFIGURATION
# ========================================
# ⚠️ WAJIB DIGANTI dengan kredensial email production
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@rssoewandhie.com
SMTP_PASS=APP_PASSWORD_GMAIL
SMTP_FROM=noreply@rssoewandhie.com

# ========================================
# AI CONFIGURATION
# ========================================
AI_PROVIDER=gemini

# OpenAI API Key (optional)
OPENAI_API_KEY=your_openai_api_key_here

# Gemini API Key
GEMINI_API_KEY=AIzaSyA6C_mHmkH0cUssr28PBWTpnDGaruHaRDc

# ========================================
# LICENSE CONFIGURATION
# ⚠️ JANGAN DIUBAH! Sudah dikonfigurasi dengan benar
# ========================================
LICENSE_KEY=5a061c063bae15b0ab98f3ba4081b43d:aabb2a43d97acd7955767633e15ee78e38dcb65f305a560a202599c819f84759ef42811b5947b008917930be240ef83a01aea3faac85d848f1620f313616348d89c0fd7581989ec6c4b162f13d6bd2a0
